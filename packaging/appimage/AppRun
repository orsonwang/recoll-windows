#! /usr/bin/env bash

# Modified from autogenerated by linuxdeploy to allow executing a
# different command by setting the RECOLL_APPIMAGE_COMMAND environment
# variable

# make sure errors in sourced scripts will cause this script to stop
set -e

this_dir="$(readlink -f "$(dirname "$0")")"

source "$this_dir"/apprun-hooks/"linuxdeploy-plugin-qt-hook.sh"

if test -z "$RECOLL_APPIMAGE_COMMAND" ; then
    exec "$this_dir"/usr/bin/recoll "$@"
else
    exec "$this_dir"/usr/bin/"$RECOLL_APPIMAGE_COMMAND" "$@"
fi
